---
import { Image } from 'astro:assets';
import { cn } from '@/lib/utils';
import FormattedDate from '@/components/FormattedDate.astro';

interface Item {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: ImageMetadata;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="grid grid-cols-1 gap-4 md:auto-rows-[22rem] md:grid-cols-3">
  {
    items.map((item, i) => (
      <a
        href={item.href}
        class={cn(
          'group/bento shadow-input row-span-1 flex flex-col space-y-4 rounded-xl border border-neutral-200 bg-white transition duration-200 hover:shadow-xl md:justify-start dark:border-white/10 dark:bg-black dark:shadow-none',
          i % 2 === 0 ? 'md:col-span-2' : 'md:col-span-1'
        )}
      >
        {item.heroImage && (
          <Image
            src={item.heroImage}
            alt={item.title}
            class="h-48 w-full rounded-t-xl border border-transparent bg-neutral-100 object-cover dark:border-white/10 dark:bg-black"
          />
        )}
        <div class="p-4 pt-0 transition duration-200 group-hover/bento:translate-x-1">
          <FormattedDate date={item.pubDate} className="text-xs" />
          <div class="mt-2 mb-2 font-sans font-bold text-neutral-600 dark:text-neutral-200">{item.title}</div>
          <div class="font-sans text-xs font-normal text-neutral-600 dark:text-neutral-300">{item.description}</div>
        </div>
      </a>
    ))
  }
</div>
